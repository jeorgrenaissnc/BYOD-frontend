<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<StackPane stylesheets="@../css/stylesheet.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.error.ErrorController">

    <Rectangle fx:id="overlay" opacity="0.6" styleClass="overlay" />

    <BorderPane maxWidth="420.0" prefWidth="420.0" styleClass="error-dialog-container">
        <top>
            <VBox styleClass="dialog-header">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <children>
                            <Label styleClass="error-icon" text="⚠" />
                            <Label fx:id="titleLabel" styleClass="title-1" text="Error" />
                        </children>
                    </HBox>
                    <Label fx:id="subtitleLabel" styleClass="description" text="An error has occurred" />
                </children>
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
                </padding>
            </VBox>
        </top>

        <center>
            <VBox spacing="15.0" styleClass="dialog-content">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <children>
                    <Label fx:id="errorMessageLabel" styleClass="error-message" text="This is where the main error message appears to inform the user about what went wrong." wrapText="true" />

                    <Separator styleClass="separator" />

                    <Label fx:id="errorDetailLabel" styleClass="error-detail" text="Additional details or suggestions for resolving the error can be placed here." wrapText="true" />
                </children>
            </VBox>
        </center>

        <bottom>
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="dialog-footer">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="10.0" />
                </padding>
                <children>
                    <Button fx:id="okButton" defaultButton="true" onAction="#handleOk" prefWidth="100.0" styleClass="dialog-button" text="OK" />
                </children>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>
